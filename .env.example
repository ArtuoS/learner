# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini

# ChromaDB
LOCAL_DATABASE=false
CHROMA_HOST=localhost       # use "chromadb" when running via docker-compose
CHROMA_PORT=8000
CHROMA_DATABASE_NAME=default_database
CHROMA_TENANT=default_tenant
CHROMA_COLLECTION_NAME=knowledge

# General
FETCH=false

# Postgres (optional - only needed for message history)
DATABASE_URL=

# Reranker
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_INITIAL_RESULTS=10
RERANKER_FINAL_RESULTS=3

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30